{
  "name": "storyblok-to-storybook",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "tools/storyblok-to-storybook/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/tools/storyblok-to-storybook",
        "main": "tools/storyblok-to-storybook/src/index.ts",
        "tsConfig": "tools/storyblok-to-storybook/tsconfig.lib.json",
        "assets": ["tools/storyblok-to-storybook/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "tools/storyblok-to-storybook/jest.config.ts"
      }
    }
  }
}
