{
  "name": "addon-nest-controls",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "tools/addon-storyblok/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/tools/addon-storyblok",
        "main": "tools/addon-storyblok/src/index.ts",
        "tsConfig": "tools/addon-storyblok/tsconfig.lib.json",
        "assets": ["tools/addon-storyblok/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["tools/addon-storyblok/**/*.ts", "tools/addon-storyblok/**/*.html"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "tools/addon-storyblok/jest.config.ts"
      }
    }
  },
  "tags": ["type:tools"]
}
