{
  "name": "modules-cms-components",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/modules/cms/components/src",
  "projectType": "library",
  "tags": ["scope:cms", "type:cms-components"],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/modules/cms/components",
        "entryFile": "libs/modules/cms/components/src/index.ts",
        "project": "libs/modules/cms/components/package.json",
        "format": ["esm", "cjs"],
        "external": ["react/jsx-runtime"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/modules/cms/components/jest.config.ts"
      }
    },
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "configDir": "libs/modules/cms/components/.storybook",
        "browse": true,
        "port": 4400,
        "uiFramework": "@storybook/react-vite"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@nx/storybook:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "configDir": "libs/modules/cms/components/.storybook",
        "outputPath": "dist/storybook/modules-cms-components",
        "uiFramework": "@storybook/react-vite"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    }
  }
}
