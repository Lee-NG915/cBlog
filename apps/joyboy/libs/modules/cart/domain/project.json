{
  "name": "modules-cart-domain",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/modules/cart/domain/src",
  "projectType": "library",
  "tags": ["type:domain", "scope:cart"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/modules/cart/domain ",
        "main": "libs/modules/cart/domain/src/index.ts",
        "tsConfig": "libs/modules/cart/domain/tsconfig.lib.json",
        "assets": ["libs/modules/cart/domain/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/modules/cart/domain/jest.config.ts"
      }
    }
  }
}
