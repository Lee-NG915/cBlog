{
  "name": "modules-promotion-services",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/modules/promotion/services/src",
  "projectType": "library",
  "tags": ["type:services", "type:shared-services", "scope:promotion"],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/modules/promotion/services",
        "main": "libs/modules/promotion/services/src/index.ts",
        "tsConfig": "libs/modules/promotion/services/tsconfig.lib.json",
        "assets": [],
        "project": "libs/modules/promotion/services/package.json",
        "compiler": "swc",
        "format": ["cjs", "esm"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/modules/promotion/services/jest.config.ts"
      }
    }
  }
}
