{
  "name": "modules-checkout-services",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/modules/checkout/services/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/modules/checkout/services",
        "main": "libs/modules/checkout/services/src/index.ts",
        "tsConfig": "libs/modules/checkout/services/tsconfig.lib.json",
        "assets": [],
        "project": "libs/modules/checkout/services/package.json",
        "compiler": "swc",
        "format": ["cjs", "esm"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/modules/checkout/services/jest.config.ts"
      }
    }
  },
  "tags": ["type:services", "scope:checkout"]
}
