{
  "name": "modules-product-components",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/modules/product/components/src",
  "projectType": "library",
  "tags": ["type:components", "scope:product"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/modules/product/components/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  },
  "build": {
    "executor": "@nx/rollup:rollup",
    "outputs": ["{options.outputPath}"],
    "options": {
      "outputPath": "dist/libs/modules/product/components",
      "tsConfig": "libs/modules/product/components/tsconfig.lib.json",
      "project": "libs/modules/product/components/package.json",
      "entryFile": "libs/modules/product/components/src/index.ts",
      "external": ["react", "react-dom", "@emotion/react/jsx-runtime"],
      "rollupConfig": "@nx/react/plugins/bundle-rollup",
      "compiler": "swc",
      "assets": [
        {
          "glob": "libs/modules/product/components/README.md",
          "input": ".",
          "output": "."
        }
      ]
    }
  }
}
