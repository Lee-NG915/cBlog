{
  "name": "modules-payment-actions",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/modules/payment/actions/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/modules/payment/actions",
        "main": "libs/modules/payment/actions/src/index.ts",
        "tsConfig": "libs/modules/payment/actions/tsconfig.lib.json",
        "assets": [],
        "project": "libs/modules/payment/actions/package.json",
        "compiler": "swc",
        "format": ["cjs", "esm"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/modules/payment/actions/jest.config.ts"
      }
    }
  },
  "tags": ["type:actions", "scope:payment"]
}
