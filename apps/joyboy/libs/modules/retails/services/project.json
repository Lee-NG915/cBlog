{
  "name": "modules-retails-services",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/modules/retails/services/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/modules/retails/services",
        "main": "libs/modules/retails/services/src/index.ts",
        "tsConfig": "libs/modules/retails/services/tsconfig.lib.json",
        "assets": ["libs/modules/retails/services/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/modules/retails/services/jest.config.ts"
      }
    }
  },
  "tags": ["type:services", "scope:retails"]
}
