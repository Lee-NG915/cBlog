{
  "name": "shared-persistence-kit",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/persistence-kit/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/persistence-kit",
        "main": "libs/shared/persistence-kit/src/index.ts",
        "tsConfig": "libs/shared/persistence-kit/tsconfig.lib.json",
        "assets": ["libs/shared/persistence-kit/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/shared/persistence-kit/jest.config.ts"
      }
    }
  },
  "tags": ["scope:shared", "type:util"]
}
