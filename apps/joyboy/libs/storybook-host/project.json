{
  "name": "storybook-host",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/storybook-host/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/storybook-host/jest.config.ts"
      }
    },
    "storybook-deps": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx storybook fortress", "nx storybook web-e2e", "nx storybook pos-e2e"],
        "parallel": true
      }
    },
    "storybook-host": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "wait-on --timeout 60000 --interval 1000 http-get://localhost:6005 http-get://localhost:6007 http-get://localhost:6008",
          "nx storybook storybook-host"
        ],
        "parallel": false
      }
    },
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "port": 6006,
        "configDir": "libs/storybook-host/.storybook"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@nx/storybook:build",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/storybook-host",
        "configDir": "libs/storybook-host/.storybook"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c libs/storybook-host/.storybook --url=http://localhost:6006"
      }
    }
  }
}
