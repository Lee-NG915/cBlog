{
  "name": "monorepo-i18n",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/monorepo-i18n/src",
  "projectType": "library",
  "tags": ["type:util"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/monorepo-i18n",
        "main": "packages/monorepo-i18n/src/index.ts",
        "tsConfig": "packages/monorepo-i18n/tsconfig.lib.json",
        "assets": ["packages/monorepo-i18n/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/monorepo-i18n/jest.config.ts"
      }
    }
  }
}
