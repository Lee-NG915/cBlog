  "scripts": {
    "proxy:sb": "node scripts/proxy-server.js --source 7010 --target 7780",
    "proxy:web": "node scripts/proxy-server.js --source 7010 --target 7780",
    "ssl:generate": "bash scripts/generate-ssl-cert.sh",
    "e2e:sentry-tags:local": "bash scripts/e2e/sentry/run-local.sh",
    "e2e:sentry-tags:server-capture": "bash scripts/e2e/sentry/run-server-capture.sh",
    "e2e:sentry-summary": "node scripts/e2e/sentry/summarize-server.mjs",
    "e2e:sentry-summary:combined": "node scripts/e2e/sentry/summarize-combined.mjs",
    "lint:observability": "bash scripts/lint/observability-diff-check.sh",
    "prepare": "node .husky/install.mjs",
    "test": "jest",
    "quality:affected": "nx affected -t lint,test --exclude=*-e2e --parallel=3 --output-style=stream",
    "quality:affected:build": "nx affected -t lint,test,build --exclude=*-e2e --parallel=3 --output-style=stream",
    "build-storybook": "NODE_OPTIONS='--max-old-space-size=16384' nx run fortress:build-storybook",
    "chromatic": "npx chromatic ",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "update:fallback:sales": "npx tsx apps/web/scripts/update-sales-fallback.ts",
    "update:fallback:cms": "npx tsx apps/web/scripts/update-basic-container-resource-fallback.ts",
    "pos:us": "nx run pos:serve --configuration=development.us",
    "pos:ca": "nx run pos:serve --configuration=development.ca",
    "pos:au": "nx run pos:serve --configuration=development.au",
    "pos:uk": "nx run pos:serve --configuration=development.uk",
    "pos:sg": "nx run pos:serve --configuration=development.sg",
    "web:us": "NODE_OPTIONS='--max-old-space-size=8192' nx run web:serve --configuration=development.us",
    "web:ca": "NODE_OPTIONS='--max-old-space-size=8192' nx run web:serve --configuration=development.ca",
    "web:au": "NODE_OPTIONS='--max-old-space-size=8192' nx run web:serve --configuration=development.au",
    "web:uk": "NODE_OPTIONS='--max-old-space-size=8192' nx run web:serve --configuration=development.uk",
    "web:sg": "NODE_OPTIONS='--max-old-space-size=8192' nx run web:serve --configuration=development.sg",
    "web:analyze": "NODE_OPTIONS='--max-old-space-size=12288' ANALYZE=true nx build web --skip-nx-cache",
    "web:build": "NODE_OPTIONS='--max-old-space-size=12288' nx build web",
    "web:build:prod": "NODE_OPTIONS='--max-old-space-size=12288' nx run web:build:production",
    "web:profile:us": "NODE_OPTIONS='--inspect' nx run web:serve --configuration=development.us",
    "web:profile:sg": "NODE_OPTIONS='--inspect' nx run web:serve --configuration=development.sg"
  },
