{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generate Component",
      "type": "shell",
      "command": "pnpm",
      "args": ["nx", "generate", "@castlery/plugin:component", "${input:componentName}"],
      "problemMatcher": []
    },
    {
      "label": "Format All Files",
      "type": "shell",
      "command": "pnpm",
      "args": ["format"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Check Format",
      "type": "shell",
      "command": "pnpm",
      "args": ["format:check"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "componentName",
      "type": "promptString",
      "description": "Please enter the file name",
      "default": "MyComponent"
    }
  ]
}

// full command: pnpm nx generate @castlery/plugin:component test-component
