{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": true,
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "sourceMap": false
  },
  "include": ["**/*.ts", "**/*.js", "**/*.cy.ts", "**/*.cy.tsx", "**/*.cy.js", "**/*.cy.jsx", "**/*.d.ts"],
  "exclude": ["**/*.stories.ts", "**/*.stories.js"],
  "references": [
    {
      "path": "./tsconfig.storybook.json"
    }
  ]
}
